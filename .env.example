# Copy to `.env` and fill in your credentials. DO NOT commit `.env`.

# ---------------------------------------------------------------------------
# A 股数据源
# ---------------------------------------------------------------------------
# Tushare Pro: https://tushare.pro  注册后在个人中心获取 token
TUSHARE_TOKEN=

# ---------------------------------------------------------------------------
# 美股 / 全球
# ---------------------------------------------------------------------------
# Alpha Vantage: https://www.alphavantage.co/support/#api-key  (免费档 5 req/min)
ALPHA_VANTAGE_KEY=

# Polygon.io: https://polygon.io  (免费档有调用限制)
POLYGON_API_KEY=

# ---------------------------------------------------------------------------
# 加密货币交易所 (只读权限即可, 不需要提现权限)
# ---------------------------------------------------------------------------
BINANCE_API_KEY=
BINANCE_API_SECRET=

OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# ---------------------------------------------------------------------------
# 数据存储路径 (默认使用项目内 data/ 目录)
# ---------------------------------------------------------------------------
QUANT_DATA_ROOT=./data

# ---------------------------------------------------------------------------
# 日志
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
