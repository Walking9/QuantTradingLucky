# ---------------------------------------------------------------------------
# Secrets / credentials  (NEVER commit these)
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
tokens/
secrets/

# ---------------------------------------------------------------------------
# Data directories (gitignore by default — add small fixtures explicitly)
# ---------------------------------------------------------------------------
data/raw/
data/processed/
data/cache/
data/downloads/
data/interim/
*.parquet
*.feather
*.h5
*.hdf5
*.db
*.sqlite

# Keep small fixtures and READMEs
!data/README.md
!tests/fixtures/**/*.parquet
!tests/fixtures/**/*.csv

# ---------------------------------------------------------------------------
# Reports (intermediate artifacts; keep source .md/.ipynb, ignore exports)
# ---------------------------------------------------------------------------
reports/**/*.html
reports/**/*.pdf
reports/**/figures/
!reports/README.md

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
Thumbs.db
Desktop.ini
